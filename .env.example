# spoti-bye configuration
# Copy to .env and fill in your values

# DB location (default: ~/.spoti-bye/playlists.db)
# PLAYLIST_DB_PATH=/path/to/your/playlists.db

# YouTube OAuth credentials (required for `spoti-bye create` and `spoti-bye auth`)
# Get these from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Enable: YouTube Data API v3
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# YouTube API key (optional — uses a separate quota pool for search)
# Get from Google Cloud Console → APIs & Services → Credentials → API Keys
YOUTUBE_API_KEY=
